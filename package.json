{
  "name": "forum-api",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node src/app.js",
    "start:dev": "nodemon src/app.js",
    "test": "vitest --run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:integration": "npm run migrate:test && vitest --run src/Infrastructures/repository/_test",
    "test:functional": "npm run migrate:test && vitest --run src/Infrastructures/http/_test",
    "migrate": "node-pg-migrate",
    "migrate:up": "node-pg-migrate up",
    "migrate:down": "node-pg-migrate down --all",
    "migrate:down:step": "node-pg-migrate down",
    "migrate:test": "node-pg-migrate --envPath .env.test up",
    "migrate:test:up": "node-pg-migrate --envPath .env.test up",
    "migrate:test:down": "node-pg-migrate --envPath .env.test down --all",
    "migrate:test:down:step": "node-pg-migrate --envPath .env.test down",
    "lint": "eslint ./"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "instances-container": "^2.0.6",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.1.7",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/eslint-plugin": "^1.6.12",
    "eslint": "^9.39.4",
    "eslint-config-dicodingacademy": "^0.9.5",
    "node-pg-migrate": "^8.0.4",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "vitest": "^4.1.0"
  }
}
